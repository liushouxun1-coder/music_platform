LLM_ENGINE=deepseek
# DeepSeek API 配置
# 1. 将本文件重命名为 .env（去掉 .example 后缀）
# 2. 替换 sk-your-key-here 为你的真实 API Key
# 3. 获取 API Key: https://platform.deepseek.com

DEEPSEEK_API_KEY=sk-045752991feb48f8a9bc1127690772d7

# 可选：选择模型
# deepseek-v4-pro:  推理能力强，适合复杂推荐（默认）
# deepseek-v4-flash: 速度快，成本低
DEEPSEEK_MODEL=deepseek-v4-pro